# --- Backend Environment Variables ---
# Database configuration (Defaults to local SQLite)
DATABASE_URL=sqlite:///./database/support.db

# Secret key for signing JWT tokens (Change this in production)
JWT_SECRET=super-secret-key-123456789-change-me

# Local Ollama AI service URL (Optional - falls back to rule-based parser if unreachable)
OLLAMA_URL=http://localhost:11434


# --- Frontend Environment Variables ---
# URL pointing to the backend API service (Vite reads this)
VITE_API_URL=http://localhost:8000
